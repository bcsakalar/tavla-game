# ================================
# Tavla Online - Environment Variables
# ================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://tavla_user:YOUR_DB_PASSWORD@localhost:5436/tavla_db

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-change-this
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session (Admin Panel)
SESSION_SECRET=your-session-secret-key-change-this

# CORS
CORS_ORIGIN=http://localhost:3000

# Game Settings (optional)
MOVE_TIMER_SECONDS=60
RECONNECT_WINDOW_SECONDS=60
ELO_K_FACTOR=32
MATCHMAKING_RANGE_INITIAL=200
MATCHMAKING_RANGE_EXPAND=400
MATCHMAKING_EXPAND_AFTER_SECONDS=30

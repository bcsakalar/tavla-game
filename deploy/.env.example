# ============================================================
# Tavla Online — Production Environment Variables
# ============================================================
# Bu dosyayı kopyalayıp .env olarak kaydedin:
#   cp .env.example .env
#
# Güçlü, rastgele secret'lar üretmek için:
#   openssl rand -base64 48
# ============================================================

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=tavla_db
POSTGRES_USER=tavla_user
POSTGRES_PASSWORD=            # openssl rand -base64 32

# ─── JWT Authentication ───────────────────────────────────
JWT_SECRET=                   # openssl rand -base64 48
JWT_REFRESH_SECRET=           # openssl rand -base64 48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Session (Admin Panel) ────────────────────────────────
SESSION_SECRET=               # openssl rand -base64 48

# ─── Game Settings (opsiyonel) ─────────────────────────────
MOVE_TIMER_SECONDS=60
RECONNECT_WINDOW_SECONDS=60
